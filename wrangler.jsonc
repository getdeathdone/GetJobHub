{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "getjobhub",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "static",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/v1/*"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
